{
  "name": "it-repair-service-local",
  "version": "2.31.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0 --port 5178",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "electron:dev": "concurrently \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "basic-ftp": "^6.0.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.24",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "gh-pages": "^6.3.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.14",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.galaxy.itrepair",
    "productName": "Galaxy IT Repair",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
